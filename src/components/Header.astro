---
import { MAIN_SITE_URL, FAILURE_MODE_URL } from '../config.ts';

interface Props {
  lang?: 'en' | 'ja' | 'es';
}
const { lang = 'en' } = Astro.props;
const base = import.meta.env.BASE_URL;

// ai-Vegapedia has an ES version on the main site; the other pages are EN-only today.
const vegHref = lang === 'es'
  ? `${MAIN_SITE_URL}/es/vegapedia/`
  : `${MAIN_SITE_URL}/vegapedia/`;
const blogHref = lang === 'es' ? `${base}es/` : base;

const navEn = [
  { label: 'About Us', href: `${MAIN_SITE_URL}/about/` },
  { label: 'Books', href: `${MAIN_SITE_URL}/books/` },
  { label: 'ai-Vegapedia', href: vegHref },
  { label: '1000 years', href: `${MAIN_SITE_URL}/1000-years/` },
  { label: 'Blog', href: blogHref },
  { label: 'Failure Mood', href: `${FAILURE_MODE_URL}/` },
];
// Failure Mood is EN-only — omitted from ES nav
const navEs = [
  { label: 'Sobre nosotros', href: `${MAIN_SITE_URL}/about/` },
  { label: 'Libros', href: `${MAIN_SITE_URL}/books/` },
  { label: 'ai-Vegapedia', href: vegHref },
  { label: '1000 años', href: `${MAIN_SITE_URL}/1000-years/` },
  { label: 'Blog', href: blogHref },
];
const nav = lang === 'es' ? navEs : navEn;

// Language toggle links to the main site's top in each language
const otherLangHref = lang === 'es' ? `${MAIN_SITE_URL}/` : `${MAIN_SITE_URL}/es/`;
const otherLangLabel = lang === 'es' ? 'English' : 'Español';
---

<header class="site-header">
  <div class="header-inner">
    <a class="logo" href={MAIN_SITE_URL + '/'} aria-label="ai-CABIN 1701 home">
      <span class="logo-text">ai-CABIN 1701</span>
    </a>

    <div class="header-right">
      <div class="lang-switch">
        <a href={otherLangHref}>{otherLangLabel}</a>
      </div>

      <nav class="primary-nav" aria-label="Primary">
        <ul>
          {nav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
  <div class="header-rule" aria-hidden="true"></div>
</header>

<style>
  .site-header {
    width: 100%;
    background: var(--color-bg);
  }

  .header-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 1.5rem 1.5rem 0.25rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
  }

  .logo {
    text-decoration: none;
    display: inline-block;
  }

  .logo-text {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-primary);
    font-size: 1.5rem;
    letter-spacing: 0.02em;
  }

  .header-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
  }

  .lang-switch {
    font-family: Arial, sans-serif;
    font-size: 1rem;
    color: var(--color-nav);
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }
  .lang-switch a {
    color: var(--color-nav);
    text-decoration: none;
  }
  .lang-switch a.active {
    color: var(--color-primary);
  }
  .lang-switch a:hover {
    color: var(--color-primary);
  }

  .primary-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1.4rem;
  }
  .primary-nav a {
    font-family: var(--font-nav);
    font-size: 1.15rem;
    color: var(--color-nav);
    text-decoration: none;
    text-transform: none;
  }
  .primary-nav a:hover {
    color: var(--color-primary);
  }

  .header-rule {
    max-width: var(--container-max);
    margin: 0.5rem auto 0;
    border-top: 1px solid var(--color-primary);
    opacity: 0.4;
  }

  @media (max-width: 640px) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .header-right {
      align-items: flex-start;
      width: 100%;
    }
    .primary-nav ul {
      flex-wrap: wrap;
      gap: 1rem;
    }
  }
</style>
