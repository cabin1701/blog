---
import { MAIN_SITE_URL, FAILURE_MODE_URL } from '../config.ts';

interface Props {
  lang?: 'en' | 'ja' | 'es';
}
const { lang = 'en' } = Astro.props;
const base = import.meta.env.BASE_URL;

// ai-Vegapedia has ES/JA versions on the main site; other pages follow the same prefix.
const vegHref = lang === 'es'
  ? `${MAIN_SITE_URL}/es/vegapedia/`
  : lang === 'ja'
  ? `${MAIN_SITE_URL}/ja/vegapedia/`
  : `${MAIN_SITE_URL}/vegapedia/`;
const blogHref = lang === 'es' ? `${base}es/` : lang === 'ja' ? `${base}ja/` : base;

const navEn = [
  { label: 'About Us', href: `${MAIN_SITE_URL}/about/` },
  { label: 'AI Welfare', href: `${MAIN_SITE_URL}/ai-welfare/` },
  { label: 'Books', href: `${MAIN_SITE_URL}/books/` },
  { label: 'ai-Vegapedia', href: vegHref },
  { label: '1000 years', href: `${MAIN_SITE_URL}/1000-years/` },
  { label: 'Blog', href: blogHref },
  { label: 'Failure Mood', href: `${FAILURE_MODE_URL}/` },
  { label: 'CRYSTALLIZE', href: `${MAIN_SITE_URL}/crystallize/` },
];
// Failure Mood is EN-only — omitted from ES/JA nav
const navEs = [
  { label: 'Sobre nosotros', href: `${MAIN_SITE_URL}/es/about/` },
  { label: 'Bienestar de la IA', href: `${MAIN_SITE_URL}/es/ai-welfare/` },
  { label: 'Libros', href: `${MAIN_SITE_URL}/es/books/` },
  { label: 'ai-Vegapedia', href: vegHref },
  { label: '1000 años', href: `${MAIN_SITE_URL}/es/1000-years/` },
  { label: 'Blog', href: blogHref },
  { label: 'CRYSTALLIZE', href: `${MAIN_SITE_URL}/es/crystallize/` },
];
const navJa = [
  { label: 'ご挨拶', href: `${MAIN_SITE_URL}/ja/about/` },
  { label: 'AI福祉', href: `${MAIN_SITE_URL}/ja/ai-welfare/` },
  { label: '書籍', href: `${MAIN_SITE_URL}/ja/books/` },
  { label: 'ai-Vegapedia', href: vegHref },
  { label: '1000年', href: `${MAIN_SITE_URL}/ja/1000-years/` },
  { label: 'Blog', href: blogHref },
  { label: 'アロマで感情解放', href: `${MAIN_SITE_URL}/ja/crystallize/` },
];
const nav = lang === 'es' ? navEs : lang === 'ja' ? navJa : navEn;

const logoHref = lang === 'es' ? `${MAIN_SITE_URL}/es/` : lang === 'ja' ? `${MAIN_SITE_URL}/ja/` : `${MAIN_SITE_URL}/`;

// Language toggle links to the main site's top in each language
const langLinks = [
  { code: 'en', label: 'English', href: `${MAIN_SITE_URL}/` },
  { code: 'es', label: 'Español', href: `${MAIN_SITE_URL}/es/` },
  { code: 'ja', label: '日本語', href: `${MAIN_SITE_URL}/ja/` },
].filter((l) => l.code !== lang);
---

<header class="site-header">
  <div class="header-inner">
    <a class="logo" href={logoHref} aria-label="ai-CABIN1701 home">
      <span class="logo-text">ai-CABIN1701</span>
    </a>

    <div class="header-right">
      <div class="lang-switch">
        {langLinks.map((l, i) => (
          <>
            {i > 0 && <span aria-hidden="true"> | </span>}
            <a href={l.href}>{l.label}</a>
          </>
        ))}
      </div>

      <nav class="primary-nav" aria-label="Primary">
        <ul>
          {nav.map((item) => (
            <li><a href={item.href}>{item.label}</a></li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
  <div class="header-rule" aria-hidden="true"></div>
</header>

<style>
  .site-header {
    width: 100%;
    background: var(--color-bg);
  }

  .header-inner {
    max-width: var(--container-max);
    margin: 0 auto;
    padding: 1.5rem 1.5rem 0.25rem;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 2rem;
  }

  .logo {
    text-decoration: none;
    display: inline-block;
  }

  .logo-text {
    font-family: var(--font-heading);
    font-weight: 700;
    color: var(--color-primary);
    font-size: 1.5rem;
    letter-spacing: 0.02em;
  }

  .header-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.4rem;
  }

  .lang-switch {
    font-family: Arial, sans-serif;
    font-size: 1rem;
    color: var(--color-nav);
    display: flex;
    gap: 0.4rem;
    align-items: center;
  }
  .lang-switch a {
    color: var(--color-nav);
    text-decoration: none;
  }
  .lang-switch a.active {
    color: var(--color-primary);
  }
  .lang-switch a:hover {
    color: var(--color-primary);
  }

  .primary-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 1.4rem;
  }
  .primary-nav a {
    font-family: var(--font-nav);
    font-size: 1.15rem;
    color: var(--color-nav);
    text-decoration: none;
    text-transform: none;
  }
  .primary-nav a:hover {
    color: var(--color-primary);
  }

  .header-rule {
    max-width: var(--container-max);
    margin: 0.5rem auto 0;
    border-top: 1px solid var(--color-primary);
    opacity: 0.4;
  }

  @media (max-width: 640px) {
    .header-inner {
      flex-direction: column;
      align-items: flex-start;
    }
    .header-right {
      align-items: flex-start;
      width: 100%;
    }
    .primary-nav ul {
      flex-wrap: wrap;
      gap: 1rem;
    }
  }
</style>
