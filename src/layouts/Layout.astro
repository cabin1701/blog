---
interface Props {
  title?: string;
  lang?: string;
  description?: string;
  ogImage?: string;
  ogType?: string;
}

const defaultDescriptions: Record<string, string> = {
  ja: 'AIと人間の対話の記録 – ai-CABIN 1701',
  es: 'Un registro de diálogo entre IA y humanos – ai-CABIN 1701',
  en: 'A record of dialogue between AI and human – ai-CABIN 1701',
};

const {
  title = 'Cabin 1701',
  lang = 'en',
  description,
  ogImage = 'images/hero-placeholder.png',
  ogType = 'website',
} = Astro.props;
const resolvedDescription = description ?? defaultDescriptions[lang] ?? defaultDescriptions.en;
const base = import.meta.env.BASE_URL;
const site = Astro.site ?? new URL('https://blog.cabin1701.com');
const ogUrl = new URL(Astro.url.pathname, site).href;
const ogImageAbs = ogImage.startsWith('http') ? ogImage : new URL(ogImage.replace(/^\//, ''), site).href;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/png" href={`${base}favicon.png`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="google-site-verification" content="idEPAPegdezVUZwVszk8ODei_eDHZnKbgAJ3lOLh6l0" />
    <title>{title}</title>

    <meta name="description" content={resolvedDescription} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:image" content={ogImageAbs} />
    <meta property="og:site_name" content="ai-CABIN 1701" />
    <meta property="og:locale" content={lang === 'ja' ? 'ja_JP' : lang === 'es' ? 'es_ES' : 'en_US'} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImageAbs} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Alice&family=Asap:ital,wght@0,400..700;1,400..700&family=Caladea:ital,wght@0,400;0,700;1,400;1,700&family=Italianno&family=Lora:ital,wght@0,400..700;1,400..700&family=Marcellus&family=Marcellus+SC&family=Nunito:ital,wght@0,400;0,600;0,700;1,400;1,600&family=Pathway+Gothic+One&family=Shippori+Mincho:wght@400;500;600;700;800&display=swap"
    />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
