---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BlogSidebar from '../../components/BlogSidebar.astro';

export async function getStaticPaths() {
  const posts = (await getCollection('blog', ({ data }) => data.lang === 'ja' && !data.draft))
    .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  return posts.map((post, i) => ({
    params: { slug: post.id.replace(/^ja-source\//, '') },
    props: {
      post,
      newer: posts[i - 1] || null,
      older: posts[i + 1] || null,
    },
  }));
}

const { post, newer, older } = Astro.props;
const { Content } = await render(post);
const base = import.meta.env.BASE_URL;
const heroUrl = (hero: string) => (hero.startsWith('http') ? hero : `${base}${hero}`);

const fmtDate = (d: Date) =>
  `${d.getFullYear()}/${String(d.getMonth() + 1).padStart(2, '0')}/${String(d.getDate()).padStart(2, '0')}`;

const slugOf = (id: string) => id.replace(/^(en|es|ja-source)\//, '');
---

<Layout title={`${post.data.title} – ai-CABIN 1701`} lang="ja">
  <Header lang="ja" />

  {post.data.hero ? (
    <section
      class="post-hero"
      aria-label={post.data.title}
      style={`background-image: url('${heroUrl(post.data.hero)}');`}
    >
      <div class="post-hero-inner">
        <h1 class="post-hero-title">{post.data.title}</h1>
        <p class="post-hero-meta">
          <span>{post.data.author ?? 'Captain Seina'}</span>
          <span class="sep">•</span>
          <time datetime={post.data.date.toISOString().slice(0, 10)}>{fmtDate(post.data.date)}</time>
        </p>
      </div>
    </section>
  ) : (
    <>
      <section
        class="blog-hero"
        aria-label="What's New?"
        style={`background-image: url('${base}images/hero-placeholder.png');`}
      >
        <div class="blog-hero-inner">
          <h1 class="blog-hero-title">What's New?</h1>
          <p class="blog-hero-sub">世界はあなたをどう扱ってる？</p>
        </div>
      </section>
      <header class="post-header-plain">
        <h1 class="post-hero-title">{post.data.title}</h1>
        <p class="post-meta-plain">
          <span>{post.data.author ?? 'Captain Seina'}</span>
          <span class="sep">•</span>
          <time datetime={post.data.date.toISOString().slice(0, 10)}>{fmtDate(post.data.date)}</time>
        </p>
      </header>
    </>
  )}

  <div class="post-shell">
    <article class="post" data-pagefind-body data-pagefind-filter="lang:ja" data-pagefind-meta={`title:${post.data.title}`}>
      <div class="post-body">
        <Content />
      </div>

      {post.data.category && post.data.category.length > 0 && (
        <div class="post-meta-row" aria-label="カテゴリー">
          <span class="post-meta-label">カテゴリー</span>
          <ul>
            {post.data.category.map((c, idx) => {
              const href = idx === 0
                ? `${base}ja/?cat=${encodeURIComponent(c)}`
                : `${base}ja/?cat=${encodeURIComponent(post.data.category[0])}%2F${encodeURIComponent(c)}`;
              return <li><a class="post-cat" href={href}>{c}</a></li>;
            })}
          </ul>
        </div>
      )}

      {post.data.tags && post.data.tags.length > 0 && (
        <div class="post-meta-row" aria-label="タグ">
          <span class="post-meta-label">タグ</span>
          <ul>
            {post.data.tags.map((t) => (
              <li><a class="post-tag" href={`${base}ja/?q=${encodeURIComponent(t)}`}>{t}</a></li>
            ))}
          </ul>
        </div>
      )}

      <nav class="post-nav" aria-label="前後の記事">
        {older ? (
          <a class="post-nav-link prev" href={`${base}ja/${slugOf(older.id)}/`}>
            <span class="post-nav-arrow">←</span>
            <span class="post-nav-label">前の記事</span>
            <span class="post-nav-title">{older.data.title}</span>
          </a>
        ) : <span></span>}
        {newer ? (
          <a class="post-nav-link next" href={`${base}ja/${slugOf(newer.id)}/`}>
            <span class="post-nav-label">次の記事</span>
            <span class="post-nav-title">{newer.data.title}</span>
            <span class="post-nav-arrow">→</span>
          </a>
        ) : <span></span>}
      </nav>
    </article>

    <BlogSidebar lang="ja" currentId={post.id} />
  </div>

  <Footer lang="ja" />
</Layout>

<style>
  .post-hero {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 7;
    max-height: 55vh;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    margin-top: 1rem;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }
  .post-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0, 0, 0, 0.05) 0%, rgba(0, 0, 0, 0.55) 100%);
    pointer-events: none;
  }
  .post-hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 1.5rem 2.5rem;
    max-width: 900px;
  }
  .post-hero-title {
    margin: 0 0 0.75rem;
    font-family: var(--font-nav);
    font-weight: 600;
    font-size: 3.2rem;
    line-height: 1.1;
    letter-spacing: 0.02em;
    color: #fffdf4;
    text-shadow: 0 2px 18px rgba(0, 0, 0, 0.45);
  }
  .post-hero-meta {
    margin: 0;
    font-family: var(--font-tagline);
    font-style: italic;
    font-size: 0.95rem;
    letter-spacing: 0.06em;
    color: rgba(255, 253, 244, 0.92);
  }
  .post-hero-meta .sep {
    margin: 0 0.5rem;
    color: var(--color-primary);
    font-style: normal;
  }

  .blog-hero {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 7;
    max-height: 60vh;
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1rem;
  }
  .blog-hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(255, 253, 244, 0.0) 0%, rgba(255, 253, 244, 0.55) 100%);
    pointer-events: none;
  }
  .blog-hero-inner {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 0 1.5rem;
  }
  .blog-hero-title {
    margin: 0;
    font-family: var(--font-heading);
    font-weight: 400;
    font-size: 4rem;
    line-height: 1.05;
    letter-spacing: 0.01em;
    color: var(--color-primary);
  }
  .blog-hero-sub {
    margin: 0.75rem 0 0;
    font-family: var(--font-italic);
    font-style: italic;
    font-weight: 500;
    font-size: 1.25rem;
    color: var(--color-tagline);
    letter-spacing: 0.02em;
  }

  .post-header-plain {
    max-width: 760px;
    margin: 2rem auto 0;
    padding: 0 1.5rem;
    text-align: center;
  }
  .post-header-plain .post-hero-title {
    color: var(--color-primary);
    text-shadow: none;
    font-size: 2.6rem;
    margin-bottom: 0.5rem;
  }
  .post-meta-plain {
    margin: 0;
    font-family: var(--font-tagline);
    font-style: italic;
    font-size: 0.9rem;
    color: var(--color-tagline);
    letter-spacing: 0.04em;
  }
  .post-meta-plain .sep {
    margin: 0 0.5rem;
    color: var(--color-primary);
    font-style: normal;
  }

  .post-shell {
    max-width: 1200px;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 5rem;
    display: grid;
    grid-template-columns: minmax(0, 760px) 260px;
    gap: 3.5rem;
    justify-content: center;
  }

  .post {
    min-width: 0;
  }

  .post-body {
    font-family: var(--font-body);
    font-size: 1.05rem;
    line-height: 1.75;
    color: var(--color-text);
  }
  .post-body :global(p) { margin: 0 0 1.25rem; }
  .post-body :global(h2) {
    font-family: var(--font-label-plain);
    font-size: 1.6rem;
    color: var(--color-primary);
    margin: 2.5rem 0 1rem;
    letter-spacing: 0.02em;
  }
  .post-body :global(h3) {
    font-family: var(--font-label-plain);
    font-size: 1.25rem;
    color: var(--color-primary);
    margin: 2rem 0 0.75rem;
  }
  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    font-style: italic;
    color: var(--color-tagline);
  }
  .post-body :global(strong) { color: var(--color-tagline); }
  .post-body :global(em) { color: var(--color-primary); font-style: italic; }
  .post-body :global(a) {
    color: var(--color-magenta);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.2em;
  }
  .post-body :global(hr) {
    border: 0;
    border-top: 1px solid rgba(208, 62, 0, 0.25);
    margin: 2.5rem auto;
    max-width: 12rem;
  }
  .post-body :global(ul), .post-body :global(ol) {
    padding-left: 1.5rem;
    margin: 0 0 1.25rem;
  }
  .post-body :global(li) { margin-bottom: 0.5rem; }
  .post-body :global(img) {
    display: block;
    width: 100%;
    height: auto;
    margin: 2rem auto;
  }

  .post-meta-row {
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px solid rgba(208, 62, 0, 0.18);
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.75rem 1rem;
  }
  .post-meta-row:first-of-type {
    margin-top: 3rem;
  }
  .post-meta-label {
    font-family: var(--font-label);
    font-style: italic;
    font-size: 0.85rem;
    letter-spacing: 0.16em;
    color: var(--color-primary);
    min-width: 5rem;
  }
  .post-meta-row ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .post-cat {
    display: inline-block;
    padding: 0.3rem 0.85rem;
    font-family: var(--font-nav);
    font-size: 0.95rem;
    letter-spacing: 0.06em;
    color: var(--color-primary);
    background: transparent;
    border: 1px solid var(--color-primary);
    border-radius: 4px;
    text-decoration: none;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .post-cat:hover {
    background: var(--color-primary);
    color: var(--color-bg);
  }
  .post-tag {
    display: inline-block;
    padding: 0.3rem 0.85rem;
    font-family: var(--font-body);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--color-tagline);
    background: rgba(8, 0, 120, 0.04);
    border: 1px solid rgba(8, 0, 120, 0.2);
    border-radius: 999px;
    text-decoration: none;
    transition: background 0.2s ease;
  }
  .post-tag:hover {
    background: rgba(8, 0, 120, 0.1);
  }

  .post-nav {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(208, 62, 0, 0.25);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 2rem;
  }
  .post-nav-link {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    text-decoration: none;
    color: var(--color-text);
    padding: 0.75rem 0;
  }
  .post-nav-link.next { text-align: right; }
  .post-nav-arrow {
    font-family: var(--font-tagline);
    font-size: 1.1rem;
    color: var(--color-primary);
  }
  .post-nav-label {
    font-family: var(--font-tagline);
    font-style: italic;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-tagline);
  }
  .post-nav-title {
    font-family: var(--font-nav);
    font-size: 1.1rem;
    line-height: 1.25;
    color: var(--color-text);
    transition: color 0.2s ease;
  }
  .post-nav-link:hover .post-nav-title {
    color: var(--color-primary);
  }

  @media (max-width: 960px) {
    .post-shell {
      grid-template-columns: 1fr;
    }
  }
  @media (max-width: 640px) {
    .blog-hero-title { font-size: 2.4rem; }
    .blog-hero-sub { font-size: 1rem; }
    .post-hero-title { font-size: 1.9rem; }
    .post-header-plain .post-hero-title { font-size: 1.7rem; }
    .post-body { font-size: 1rem; }
    .post-nav { grid-template-columns: 1fr; gap: 1.5rem; }
    .post-nav-link.next { text-align: left; }
  }
</style>
